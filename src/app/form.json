
[
    {
      "type": "text",
      "name": "companyName",
      "label": "Company Name",
      "validators": [
        {
          "type": "required"
        },
        {
          "type": "minLength",
          "value": 3
        }
      ]
    },
    {
      "type": "email",
      "name": "email",
      "label": "Company Email",
      "validators": [
        {
          "type": "required"
        },
        {
          "type": "email"
        }
      ]
    },
    {
      "type": "checkbox",
      "name": "gstRegistered",
      "label": "GST Registered"
    },
    {
      "type": "text",
      "name": "gstNumber",
      "label": "GST Number",
      "visibleWhen": {
        "field": "gstRegistered",
        "value": true
      },
      "validators": [
        {
          "type": "required"
        },
        {
          "type": "pattern",
          "value": "^[0-9]{2}[A-Z]{5}[0-9]{4}[A-Z]{1}[A-Z0-9]{3}$"
        }
      ]
    },
    {
      "type": "select",
      "name": "businessType",
      "label": "Business Type",
      "validators": [
        {
          "type": "required"
        }
      ],
      "options": [
        {
          "label": "Product",
          "value": "product"
        },
        {
          "label": "Service",
          "value": "service"
        }
      ]
    },
    {
      "type": "group",
      "name": "address",
      "label": "Address",
      "fields": [
        {
          "type": "text",
          "name": "street",
          "label": "Street",
          "validators": [
            {
              "type": "required"
            }
          ]
        },
        {
          "type": "text",
          "name": "city",
          "label": "City",
          "validators": [
            {
              "type": "required"
            }
          ]
        },
        {
          "type": "text",
          "name": "state",
          "label": "State",
          "validators": [
            {
              "type": "required"
            }
          ]
        },
        {
          "type": "text",
          "name": "zipCode",
          "label": "Zip Code",
          "validators": [
            {
              "type": "required"
            },
            {
              "type": "pattern",
              "value": "^[0-9]{6}$"
            }
          ]
        }
      ]
    },
    {
      "type": "array",
      "name": "contacts",
      "label": "Contacts",
      "minItems": 1,
      "fields": [
        {
          "type": "text",
          "name": "name",
          "label": "Contact Name",
          "validators": [
            {
              "type": "required"
            }
          ]
        },
        {
          "type": "email",
          "name": "email",
          "label": "Contact Email",
          "validators": [
            {
              "type": "required"
            },
            {
              "type": "email"
            }
          ]
        },
        {
          "type": "text",
          "name": "phone",
          "label": "Phone Number",
          "validators": [
            {
              "type": "required"
            },
            {
              "type": "pattern",
              "value": "^[0-9]{10}$"
            }
          ]
        }
      ]
    }
  ]
